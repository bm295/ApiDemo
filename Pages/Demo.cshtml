@page "{id?}"
@model FunctionalProgramming.Pages.DemoModel
@{
    ViewData["Title"] = "API Demo";
}

<h2>@Model.Title</h2>
<p>@Model.Description</p>
@if (Model.IsRestDemo)
{
    <p><strong>Why REST is stateless:</strong> @Model.RestStatelessNote</p>
    <p><strong>Uniform Interface:</strong> @Model.RestUniformInterfaceNote</p>
    <pre>@Model.RestUniformInterfaceExample</pre>
    <p>
        Method:
        <a asp-page="/Demo" asp-route-id="rest" asp-route-method="GET">GET</a> |
        <a asp-page="/Demo" asp-route-id="rest" asp-route-method="POST">POST</a>
    </p>
    <h3>Request (@Model.SelectedMethod)</h3>
    <pre>@Model.RestRequestExample</pre>
    <h3>Response (@Model.SelectedMethod)</h3>
    <pre>@Model.RestResponseExample</pre>
}
else if (Model.IsGraphQlDemo)
{
    <p>
        Example:
        <a asp-page="/Demo" asp-route-id="graphql" asp-route-example="1">Example 1 (schema introspection)</a> |
        <a asp-page="/Demo" asp-route-id="graphql" asp-route-example="2">Example 2 (schema validation error)</a>
    </p>
    <h3>Request (Example @Model.SelectedGraphQlExample)</h3>
    <pre>@Model.GraphQlRequestExample</pre>
    <h3>Response (Example @Model.SelectedGraphQlExample)</h3>
    <pre>@Model.GraphQlResponseExample</pre>
}
else if (Model.IsGrpcDemo)
{
    <p><strong>Why gRPC is high performance:</strong> @Model.GrpcHighPerformanceNote</p>
    <h3>Request</h3>
    <pre>@Model.GrpcRequestExample</pre>
    <h3>Response</h3>
    <pre>@Model.GrpcResponseExample</pre>
}
else
{
    <pre>@Model.Example</pre>
}
